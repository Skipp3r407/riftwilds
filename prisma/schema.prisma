/// MAP_TEMPLATE catalog row (data-driven; runtime also ships code defaults).
model MapTemplate {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  key                    String   @unique
  name                   String
  biome                  String
  mapKind                String
  blurb                  String
  housingStylesJson      Json
  districtKindsJson      Json
  hubsJson               Json
  roadStyle              String
  performanceBudgetJson  Json
  softPlayerLimit        Int
  hardPlayerLimit        Int
  targetPlotMin          Int
  targetPlotMax          Int
  allowsPermanentHousing Boolean
  generatorVersion       String
}

model ExpansionRequest {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  requestId        String   @unique
  reason           String
  sourceMapId      String?
  templateKey      String
  mapKind          String
  lifecycle        String
  priority         Int      @default(50)
  jobId            String?
  resultingMapId   String?
  note             String?
  adminActorId     String?

  sourceMap    WorldMap? @relation("ExpansionSource", fields: [sourceMapId], references: [mapId])
  resultingMap WorldMap? @relation("ExpansionResult", fields: [resultingMapId], references: [mapId])
  jobs         GenerationJob[]

  @@index([lifecycle, priority])
  @@index([sourceMapId])
}

model GenerationJob {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  jobId              String   @unique
  expansionRequestId String
  status             String
  attempts           Int      @default(0)
  maxAttempts        Int      @default(3)
  seed               String
  templateKey        String
  mapId              String?
  lastError          String?

  request ExpansionRequest @relation(fields: [expansionRequestId], references: [requestId], onDelete: Cascade)
  map     WorldMap?        @relation(fields: [mapId], references: [mapId])

  @@index([status])
  @@index([expansionRequestId])
}

model CapacityMetric {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  mapId              String
  playersOnline      Int
  plotsOccupied      Int
  plotsTotal         Int
  visitors           Int
  entityCount        Int
  tickLatencyMs      Int
  softPlayerLimit    Int
  hardPlayerLimit    Int
  rollingLoadAvg     Float
  spikeDetected      Boolean  @default(false)
  forecastNeedsExpansion Boolean @default(false)
  forecastNeedsOverflow  Boolean @default(false)
  payloadJson        Json?

  map WorldMap @relation(fields: [mapId], references: [mapId], onDelete: Cascade)

  @@index([mapId, createdAt])
}

model PlayerMapAssignment {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String   @unique
  mapId       String
  reason      String
  assignedAt  DateTime @default(now())
  stickyUntil DateTime?

  map WorldMap @relation(fields: [mapId], references: [mapId], onDelete: Cascade)

  @@index([mapId])
}

model RelocationRequest {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  relocationId          String   @unique
  userId                String
  fromMapId             String
  toMapId               String
  fromPlotId            String?
  toPlotId              String?
  status                String
  snapshotHash          String?
  furnitureIdsJson      Json
  idempotencyKey        String   @unique
  guildApprovalRequired Boolean  @default(false)
  guildApprovedBy       String?
  error                 String?

  fromMap WorldMap @relation("RelocateFrom", fields: [fromMapId], references: [mapId])
  toMap   WorldMap @relation("RelocateTo", fields: [toMapId], references: [mapId])

  @@index([userId, status])
  @@index([toMapId])
}

model ValidationReport {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  reportId        String   @unique
  mapId           String
  passed          Boolean
  checksJson      Json
  visualQaJson    Json

  map WorldMap @relation(fields: [mapId], references: [mapId], onDelete: Cascade)

  @@index([mapId, passed])
}

// ─── Player feedback (prepared — apply migration only after approval) ─
/// Anonymous public bug / idea intake. Runtime uses in-memory store until migrated.
model PlayerFeedback {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  kind         String // bug | feedback
  status       String   @default("OPEN")
  title        String?
  category     String?
  severity     String?
  message      String
  email        String?
  pageUrl      String?
  userAgent    String?
  source       String?
  metadataJson Json?
  requestId    String?

  @@index([status, createdAt])
  @@index([kind, createdAt])
}

// ─── Friends + private messages (PREPARED ONLY) ───────────────────────────────
// Hot path: src/lib/social (in-memory). Enable FRIENDS_AND_PM_PRISMA_ENABLED
// only after migrate deploy approval. ownerKey is user_* or guest_* (no wallet required).

model SocialProfileRow {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ownerKey        String   @unique
  handle          String   @unique
  displayName     String
  rankTitle       String   @default("Hatchling Keeper")
  avatarSrc       String?
  messagePrivacy  String   @default("friends_only")
  lastSeenAt      DateTime @default(now())
  systemKeeper    Boolean  @default(false)

  @@index([lastSeenAt])
}

model FriendshipRow {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  ownerKeyA  String
  ownerKeyB  String

  @@unique([ownerKeyA, ownerKeyB])
  @@index([ownerKeyA])
  @@index([ownerKeyB])
}

model FriendRequestRow {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fromOwnerKey  String
  toOwnerKey    String
  status        String   @default("pending")
  note          String?

  @@index([toOwnerKey, status])
  @@index([fromOwnerKey, status])
}

model SocialBlockRow {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  blockerOwnerKey  String
  blockedOwnerKey  String
  reason           String?

  @@unique([blockerOwnerKey, blockedOwnerKey])
  @@index([blockerOwnerKey])
}

model DirectMessageThreadRow {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  ownerKeyA      String
  ownerKeyB      String
  lastMessageAt  DateTime?

  messages DirectMessageRow[]

  @@unique([ownerKeyA, ownerKeyB])
  @@index([lastMessageAt])
}

model DirectMessageRow {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  threadId        String
  senderOwnerKey  String
  body            String
  readAt          DateTime?

  thread DirectMessageThreadRow @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderOwnerKey])
}

model SocialReportRow {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  reporterOwnerKey   String
  targetOwnerKey     String
  targetType         String
  targetId           String
  reason             String
  details            String?
  status             String   @default("open")

  @@index([status, createdAt])
  @@index([reporterOwnerKey])
}

// ─── Project Treasury Ops (Pump.fun → single treasury → distribution) ────────
// Local demo persists to `.data/treasury-ops/state.json`. These models are the
// production-ready Prisma proposal; migrate when ops persistence is approved.
// Never models player P2W escrow or holder dividend autopay.

model ProjectTreasuryWallet {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  role                 String
  name                 String
  description          String
  address              String
  network              String   @default("devnet")
  asset                String   @default("SOL")
  isActive             Boolean  @default(true)
  isDistributionTarget Boolean  @default(false)
  percentBps           Int      @default(0)

  balances ProjectWalletBalance[]

  @@unique([address, network, asset])
  @@index([role, isActive])
}

model ProjectWalletBalance {
  id         String   @id @default(cuid())
  updatedAt  DateTime @updatedAt
  walletId   String
  asset      String   @default("SOL")
  balanceRaw String   @default("0")
  verified   Boolean  @default(false)
  isDemo     Boolean  @default(true)

  wallet ProjectTreasuryWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, asset])
}

model ProjectDistributionRules {
  id                             String   @id @default(cuid())
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  version                        Int      @unique
  label                          String
  active                         Boolean  @default(true)
  /// JSON map walletId → bps (must sum 10000)
  splitsJson                     Json
  minDistributionLamports        String   @default("10000000")
  distributionDelayMs            Int      @default(5000)
  autoApprovalThresholdLamports  String   @default("1000000000")
}

model ProjectIncomingTransaction {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sourceKey         String
  category          String
  asset             String   @default("SOL")
  amountLamports    String
  senderAddress     String
  recipientAddress  String
  txSignature       String?
  idempotencyKey    String   @unique
  confirmations     Int      @default(0)
  status            String   @default("PENDING_VERIFY")
  verifiedAt        DateTime?
  metadata          Json?

  processed ProjectProcessedTransaction?

  @@index([status, createdAt])
  @@index([txSignature])
  @@index([sourceKey, createdAt])
}

model ProjectProcessedTransaction {
  id              String   @id @default(cuid())
  processedAt     DateTime @default(now())
  incomingId      String   @unique
  idempotencyKey  String   @unique
  distributionId  String?
  note            String

  incoming ProjectIncomingTransaction @relation(fields: [incomingId], references: [id], onDelete: Cascade)
}

model ProjectDistributionHistory {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  incomingId       String?
  ruleVersion      Int
  status           String
  grossLamports    String
  asset            String   @default("SOL")
  linesJson        Json
  requiresApproval Boolean  @default(false)
  approvedBy       String?
  approvedAt       DateTime?
  idempotencyKey   String   @unique
  previewOnly      Boolean  @default(false)
  simulated        Boolean  @default(false)
  error            String?
  executedAt       DateTime?

  pending  ProjectPendingDistribution?
  failed   ProjectFailedDistribution?
  approval ProjectManualApproval?

  @@index([status, createdAt])
}

model ProjectPendingDistribution {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  distributionId String   @unique
  queuedAt       DateTime @default(now())

  distribution ProjectDistributionHistory @relation(fields: [distributionId], references: [id], onDelete: Cascade)
}

model ProjectFailedDistribution {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  distributionId String   @unique
  reason         String
  retryCount     Int      @default(0)
  lastError      String
  nextRetryAt    DateTime?

  distribution ProjectDistributionHistory @relation(fields: [distributionId], references: [id], onDelete: Cascade)

  @@index([nextRetryAt])
}

model ProjectManualApproval {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  distributionId String   @unique
  requestedAt    DateTime @default(now())
  requestedBy    String?
  status         String   @default("PENDING")
  decidedBy      String?
  decidedAt      DateTime?
  note           String?

  distribution ProjectDistributionHistory @relation(fields: [distributionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model ProjectTreasuryAuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  requestId  String?
  metadata   Json?

  @@index([createdAt])
  @@index([action, createdAt])
}

model ProjectTreasurySystemSettings {
  id            String   @id @default("singleton")
  updatedAt     DateTime @updatedAt
  settingsJson  Json
}

model ProjectTreasuryReport {
  id               String   @id @default(cuid())
  generatedAt      DateTime @default(now())
  period           String
  periodStart      DateTime
  periodEnd        DateTime
  totalInLamports  String
  totalOutLamports String
  bySourceJson     Json
  byWalletJson     Json
  healthScore      Int

  @@index([period, generatedAt])
}

// ─── Rift Stakes (optional SOL wager — DEMO store also in .data/rift-stakes) ─

model RiftStakeMatch {
  id              String   @id @default(cuid())
  publicId        String   @unique
  status          String
  stakeTierId     String
  hostOwnerKey    String
  guestOwnerKey   String?
  winnerOwnerKey  String?
  feeSnapshotJson Json?
  demoMode        Boolean  @default(true)
  createdAt       DateTime @default(now())
  completedAt     DateTime?
  escrow          RiftStakeEscrow?
  feeRows         RiftStakeFee[]

  @@index([hostOwnerKey, createdAt])
  @@index([status, createdAt])
}

model RiftStakeEscrow {
  id                     String   @id @default(cuid())
  matchId                String   @unique
  phase                  String
  stakePerPlayerLamports BigInt
  hostWallet             String?
  guestWallet            String?
  hostDeposited          Boolean  @default(false)
  guestDeposited         Boolean  @default(false)
  demoMode               Boolean  @default(true)
  onChainTxIdsJson       Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  match                  RiftStakeMatch @relation(fields: [matchId], references: [id])
}

model RiftStakeTreasury {
  id                    String   @id @default("singleton")
  treasuryWallet        String
  collectedFeesLamports BigInt   @default(0)
  updatedAt             DateTime @updatedAt
}

model RiftStakeTreasuryTransaction {
  id             String   @id @default(cuid())
  kind           String
  matchId        String?
  escrowId       String?
  amountLamports BigInt
  bucket         String?
  note           String
  demoMode       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model RiftStakeFeeHistory {
  id                     String   @id @default(cuid())
  matchId                String
  feeBps                 Int
  platformFeeLamports    BigInt
  prizePoolLamports      BigInt
  winnerReceivesLamports BigInt
  charged                Boolean
  reason                 String
  createdAt              DateTime @default(now())

  @@index([matchId])
}

model RiftStakeFee {
  id      String         @id @default(cuid())
  matchId String
  feeBps  Int
  charged Boolean
  match   RiftStakeMatch @relation(fields: [matchId], references: [id])
}

model RiftStakePromotion {
  id       String   @id @default(cuid())
  name     String
  feeBps   Int
  active   Boolean  @default(false)
  startsAt DateTime
  endsAt   DateTime
  note     String?
}

model RiftStakeVipFee {
  id         String @id @default(cuid())
  label      String
  feeBps     Int
  minMatches Int
  note       String?
}
