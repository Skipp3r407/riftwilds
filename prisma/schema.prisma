// ─── Live World persistence / session / save-state ───────────────────────────

enum WorldPlaySessionStatus {
  ACTIVE
  RECONNECTING
  DISCONNECTED
  LOGGED_OUT_SAFE
  LOGGED_OUT_UNSAFE
  EXPIRED
  FORCE_ENDED
}

enum SaveCategory {
  A_CRITICAL
  B_PROGRESSION
  C_COSMETIC
}

enum LogoutZoneKind {
  INN
  HOME
  CAMP
  SETTLEMENT
  WAYPOINT
}

/// Server-authoritative Live World presence lease (Phase 1: REST heartbeat;
/// Phase 2+: WebSocket lease). Separate from auth Session cookie.
model WorldPlaySession {
  id                String                 @id @default(cuid())
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  userId            String?
  /// Demo / guest identity when no User row (sess_* / guest_*).
  ownerKey          String
  authSessionId     String?
  status            WorldPlaySessionStatus @default(ACTIVE)
  mapId             String                 @default("riftwild-commons")
  posX              Int                    @default(1024)
  posY              Int                    @default(768)
  facingRad         Float                  @default(0)
  inCombat          Boolean                @default(false)
  combatStartedAt   DateTime?
  lastHeartbeatAt   DateTime               @default(now())
  lastAutosaveAt    DateTime?
  reconnectDeadline DateTime?
  disconnectAt      DateTime?
  logoutZoneId      String?
  logoutZoneKind    LogoutZoneKind?
  clientInstanceId  String?
  version           Int                    @default(0)
  dirtyFlagsJson    Json?
  metadata          Json?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ownerKey, status])
  @@index([userId, status])
  @@index([lastHeartbeatAt])
  @@index([reconnectDeadline])
  @@index([status, updatedAt])
}

/// Authoritative layered save blob for Category B/C progression.
/// Category A (credits/ownership) stays on CurrencyLedger / inventory ledgers.
model WorldSaveState {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  userId             String?
  ownerKey           String
  version            Int      @default(0)
  mapId              String   @default("riftwild-commons")
  posX               Int      @default(1024)
  posY               Int      @default(768)
  lastSafeMapId      String?
  lastSafePosX       Int?
  lastSafePosY       Int?
  lastSafeZoneId     String?
  lastSafeZoneKind   LogoutZoneKind?
  playStateJson      Json?
  dirtyCategoryA     Boolean  @default(false)
  dirtyCategoryB     Boolean  @default(false)
  dirtyCategoryC     Boolean  @default(false)
  lastCategoryAAt    DateTime?
  lastCategoryBAt    DateTime?
  lastCategoryCAt    DateTime?
  lastRequestId      String?
  schemaVersion      Int      @default(1)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ownerKey])
  @@index([userId])
  @@index([updatedAt])
}

/// Point-in-time snapshots for crash recovery / admin rollback stubs.
model WorldSaveSnapshot {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  userId        String?
  ownerKey      String
  version       Int
  reason        String
  category      SaveCategory @default(B_PROGRESSION)
  mapId         String
  posX          Int
  posY          Int
  payloadJson   Json
  requestId     String?      @unique

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ownerKey, createdAt])
  @@index([userId, createdAt])
}

/// Last confirmed safe logout / rest checkpoint (inn / home / camp).
model SafeLogoutCheckpoint {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  userId      String?
  ownerKey    String
  mapId       String
  posX        Int
  posY        Int
  zoneId      String
  zoneKind    LogoutZoneKind
  restBonusApplied Boolean   @default(false)
  loggedOutAt DateTime       @default(now())
  requestId   String?        @unique

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ownerKey])
  @@index([userId])
}

/// Optional lightweight sleep stub visible to visitors when housing privacy allows.
/// Default OFF — characters are removed from the world on logout.
model SleepingCharacterStub {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?
  ownerKey        String
  mapId           String
  posX            Int
  posY            Int
  displayName     String?
  appearanceJson  Json?
  /// Only when Homestead.visitPolicy allows and feature flag is on.
  visibleToVisitors Boolean @default(false)
  expiresAt       DateTime
  active          Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ownerKey])
  @@index([mapId, active])
  @@index([expiresAt])
}

/// Idempotent persistence mutations (autosave / logout / restore).
model WorldSaveIdempotency {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  ownerKey   String
  requestId  String
  route      String
  responseJson Json?
  expiresAt  DateTime

  @@unique([ownerKey, requestId, route])
  @@index([expiresAt])
}

