generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TokenTier {
  VISITOR
  KEEPER
  RANGER
  WARDEN
  FOUNDER
}

/// Account lifecycle — NO ACCOUNT = NO GAMEPLAY. Guest play is not a status.
enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
  UNDER_REVIEW
  PARENTAL_CONSENT_REQUIRED
  RECOVERY_PENDING
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
  CELESTIAL
}

enum AffinityName {
  EMBER
  TIDE
  GROVE
  STORM
  STONE
  FROST
  RADIANT
  VOID
  ALLOY
  SPIRIT
}

enum MatchupResult {
  STRONG
  WEAK
  RESIST
  NEUTRAL
}

enum EggClass {
  WILD
  EMBER
  TIDE
  GROVE
  STORM
  ANCIENT
  VOID
  CELESTIAL
  EVENT
}

enum EggAcquisitionMethod {
  STARTER_CLAIM
  QUEST_REWARD
  EVENT
  ADMIN_PROMO
  SHOP
  ALLOWLIST
}

enum EggStatus {
  UNCLAIMED
  OWNED
  INCUBATING
  READY
  HATCHED
  EXPIRED
  REVOKED
}

enum CreatureLifecycle {
  THRIVING
  HAPPY
  STABLE
  TIRED
  NEGLECTED
  DORMANT
  CRITICAL
  MEMORIALIZED
  RETIRED
}

enum AbilityCategory {
  STRIKE
  GUARD
  RESTORE
  CONTROL
  BOOST
  WEAKEN
  FIELD
}

enum ItemCategory {
  FOOD
  CARE
  TRAINING
  EXPLORATION
  BATTLE
  CRAFTING
  EVOLUTION
  COSMETIC
  EVENT
  QUEST
  WEAPON
  ARMOR
  POTION
  SCROLL
  MATERIAL
  RECOVERY
}

enum QuestCategory {
  STORY
  DAILY
  WEEKLY
  EXPLORATION
  CARE
  BATTLE
  COLLECTION
  COMMUNITY
  EVENT
}

enum BattleStatus {
  PENDING
  ACTIVE
  COMPLETED
  FORFEITED
  EXPIRED
}

enum MarketplaceListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum MarketplaceListingKind {
  EGG
  PET
  ITEM
}

enum MarketplaceListingCategory {
  EGGS
  PETS
  EQUIPMENT
  CONSUMABLES
  PROPERTY
}

enum ListingBundleMode {
  PET_ONLY
  PET_PLUS_LOADOUT
}

enum EggSourceKind {
  STARTER
  OFFICIAL_SEASONAL
  STORY_ACHIEVEMENT
  BREEDING
  COMMUNITY_EVENT
  LIMITED_COLLECTOR
}

enum CraftingJobStatus {
  QUEUED
  IN_PROGRESS
  READY
  CLAIMED
  CANCELLED
}

enum RandomnessSource {
  SERVER_CSPRNG
  FUTURE_VRF
}

enum NotificationType {
  EGG_READY
  CARE_NEEDED
  DORMANT
  QUEST_COMPLETE
  MARKETPLACE_SALE
  MARKETPLACE_PURCHASE
  EVOLUTION_AVAILABLE
  REGION_UNLOCKED
  EVENT_BEGIN
  BOSS_MILESTONE
  TIER_CHANGED
  SYSTEM
}

enum LeaderboardKind {
  PLAYER_LEVEL
  COLLECTION
  BATTLE_RATING
  QUEST_POINTS
  CARE_STREAK
  CREATURE_BOND
  RARE_DISCOVERIES
  EVENT_POINTS
  BOSS_CONTRIBUTION
  MARKETPLACE_VOLUME
}

enum SeasonScope {
  WEEKLY
  SEASONAL
  ALL_TIME
}

// ─── Auth & Users ────────────────────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  primaryWalletId String?       @unique
  role            String        @default("player")
  /** Canonical account lifecycle. isBanned is kept for legacy checks. */
  accountStatus   AccountStatus @default(PENDING_VERIFICATION)
  email           String?       @unique
  emailNormalized String?       @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  lockedUntil     DateTime?
  failedLoginCount Int          @default(0)
  region          String?
  dateOfBirth     DateTime?
  parentalConsentAt DateTime?
  onboardingCompletedAt DateTime?
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  lastLoginAt     DateTime?
  rememberMeDefault Boolean     @default(false)
  isBanned        Boolean       @default(false)
  banReason       String?
  suspiciousScore Int           @default(0)

  wallets              Wallet[]
  sessions             Session[]
  authIdentities       AuthIdentity[]
  authAccounts         AuthAccount[]
  authNonces           AuthNonce[]
  profile              PlayerProfile?
  settings             PlayerSettings?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  loginAttempts        LoginAttempt[]
  trustedDevices       TrustedDevice[]
  accountStatusHistory AccountStatusHistory[]
  termsAcceptances     TermsAcceptance[]
  privacyAcceptances   PrivacyAcceptance[]
  securityAuditLogs    SecurityAuditLog[]
  linkedWallets        LinkedWallet[]
  tokenSnapshots       TokenBalanceSnapshot[]
  eggs                 Egg[]
  creatures            Creature[]               @relation("CreatureOwner")
  originallyOwned      Creature[]               @relation("CreatureOriginalOwner")
  careEvents           CreatureCareEvent[]
  inventory            InventoryItem[]
  itemTransactions     ItemTransaction[]
  craftingJobs         CraftingJob[]
  regionProgress       PlayerRegionProgress[]
  encounters           Encounter[]
  battlesAsChallenger  Battle[]                 @relation("BattleChallenger")
  battlesAsDefender    Battle[]                 @relation("BattleDefender")
  quests               PlayerQuest[]
  achievements         PlayerAchievement[]
  marketplaceListings  MarketplaceListing[]
  marketplacePurchases MarketplaceSale[]        @relation("SaleBuyer")
  marketplaceSales     MarketplaceSale[]        @relation("SaleSeller")
  currencyLedger       CurrencyLedger[]
  rewardLedger         RewardLedger[]
  withdrawals          WithdrawalRequest[]
  bossAttempts         BossAttempt[]
  leaderboardEntries   LeaderboardEntry[]
  notifications        Notification[]
  auditLogs            AuditLog[]               @relation("AuditActor")
  adminActions         AdminAction[]
  disclosureAccepts    UserDisclosureAcceptance[]
  memorials            Memorial[]
  moderationReports    ModerationReport[]       @relation("ReportReporter")
  hatchAttempts        HatchAttempt[]
  idempotencyKeys      IdempotencyKey[]
  arenaRatings         ArenaRating[]
  arenaPointLedgers    ArenaPointLedger[]
  duelChallengesSent   DuelChallenge[]          @relation("DuelChallenger")
  duelChallengesRecv   DuelChallenge[]          @relation("DuelOpponent")
  arenaBattles         ArenaBattle[]            @relation("ArenaBattleOwner")
  communityPredictions CommunityPrediction[]
  petBattleLoadouts    PetBattleLoadout[]
  weaponInstances      WeaponInstance[]
  arenaSuspensions     ArenaSuspension[]
  itemPurchases        ItemPurchase[]
  paymentIntents       PaymentIntent[]
  petLoadouts          PetLoadout[]
  worldPlaySessions    WorldPlaySession[]
  worldSaveStates      WorldSaveState[]
  worldSaveSnapshots   WorldSaveSnapshot[]
  safeLogoutCheckpoints SafeLogoutCheckpoint[]
  sleepingCharacters   SleepingCharacterStub[]
  presenceProfiles     PlayerPresenceProfile[]

  @@index([role])
  @@index([createdAt])
  @@index([accountStatus])
  @@index([emailNormalized])
}

model Wallet {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  address      String
  network      String    @default("devnet")
  isPrimary    Boolean   @default(false)
  verifiedAt   DateTime?
  lastSeenAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([address, network])
  @@index([userId])
  @@index([address])
}

model AuthNonce {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  userId     String?
  wallet     String
  nonce      String    @unique
  requestId  String
  domain     String
  issuedAt   DateTime
  expiresAt  DateTime
  usedAt     DateTime?
  ipHash     String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([wallet])
  @@index([expiresAt])
}

model Session {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  userId           String
  /** Optional — email/social sessions may exist without a linked wallet. */
  walletAddress    String?
  tokenHash        String    @unique
  /** Rotating refresh credential hash (httpOnly cookie companion). */
  refreshTokenHash String?   @unique
  refreshExpiresAt DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  userAgentHash    String?
  ipHash           String?
  deviceId         String?
  rememberMe       Boolean   @default(false)
  lastSeenAt       DateTime  @default(now())
  csrfSecretHash   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([deviceId])
}

/// Provider credential row (email password / OAuth). Complements AuthIdentity.
model AuthAccount {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String
  provider          String
  providerAccountId String
  email             String?
  accessTokenEnc    String?
  refreshTokenEnc   String?
  expiresAt         DateTime?
  scope             String?
  tokenType         String?
  idTokenEnc        String?
  passwordHash      String?
  verifiedAt        DateTime?
  lastUsedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  userId    String
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  ipHash    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  email       String?
  userId      String?
  success     Boolean
  reason      String?
  ipHash      String?
  userAgentHash String?
  provider    String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
}

model TrustedDevice {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  deviceKeyHash String
  label        String?
  userAgentHash String?
  ipHash       String?
  lastSeenAt   DateTime  @default(now())
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceKeyHash])
  @@index([userId])
}

model AccountStatusHistory {
  id         String        @id @default(cuid())
  createdAt  DateTime      @default(now())
  userId     String
  fromStatus AccountStatus?
  toStatus   AccountStatus
  reason     String?
  actorId    String?
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TermsAcceptance {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  version     String
  acceptedAt  DateTime @default(now())
  ipHash      String?
  userAgentHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, version])
  @@index([userId])
}

model PrivacyAcceptance {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  version     String
  acceptedAt  DateTime @default(now())
  ipHash      String?
  userAgentHash String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, version])
  @@index([userId])
}

model SecurityAuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ipHash     String?
  userAgentHash String?
  requestId  String?
  metadata   Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

/// Wallet linked only after a signed-in account exists (never replaces account).
model LinkedWallet {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  address      String
  network      String    @default("devnet")
  isPrimary    Boolean   @default(false)
  verifiedAt   DateTime?
  linkedAt     DateTime  @default(now())
  unlinkedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([address, network])
  @@index([userId])
}

/// Modular auth identities (email / OAuth / bridges). Wallet SIWS still uses Wallet + Session.
model AuthIdentity {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         String
  provider       String
  providerUserId String
  email          String?
  displayName    String?
  avatarUrl      String?
  rawProfileJson Json?
  verifiedAt     DateTime?
  lastUsedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([email])
}

model PlayerProfile {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  userId             String    @unique
  username           String?   @unique
  displayName        String?
  avatarKey          String?
  bio                String?
  level              Int       @default(1)
  experience         Int       @default(0)
  rankTitle          String    @default("Hatchling Keeper")
  tokenTier          TokenTier @default(VISITOR)
  joinDate           DateTime  @default(now())
  lastActiveAt       DateTime  @default(now())
  inventoryCapacity  Int       @default(40)
  creatureCapacity   Int       @default(12)
  publicProfile      Boolean   @default(true)
  starterEggClaimed  Boolean   @default(false)
  starterKeeperChosen Boolean  @default(false)
  tutorialIntroSeen  Boolean   @default(false)
  demoCredits        Int       @default(10000)
  softCurrency       Int       @default(0)
  careStreak         Int       @default(0)
  battleRating       Int       @default(1000)
  questPoints        Int       @default(0)
  eventPoints        Int       @default(0)
  version            Int       @default(0)
  lastLocationPath   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([level])
  @@index([tokenTier])
  @@index([battleRating])
}

model PlayerSettings {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  userId                String   @unique
  reducedMotion         Boolean  @default(false)
  soundEnabled          Boolean  @default(true)
  musicVolume           Int      @default(70)
  sfxVolume             Int      @default(80)
  notificationsEnabled  Boolean  @default(true)
  emailOptIn            Boolean  @default(false)
  skipHatchAnimations   Boolean  @default(false)
  lowPowerMode          Boolean  @default(false)
  locale                String   @default("en")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Token ───────────────────────────────────────────────────────────────────

model TokenBalanceSnapshot {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  userId      String
  wallet      String
  mint        String
  amountRaw   String
  decimals    Int
  tier        TokenTier
  slot        BigInt?
  source      String
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([wallet, mint])
}

model TokenGateRule {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tier        TokenTier @unique
  minAmount   String
  label       String
  description String
  benefits    Json
  active      Boolean   @default(true)
}

// ─── Affinities & Species ────────────────────────────────────────────────────

model Affinity {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  name        AffinityName @unique
  slug        String       @unique
  displayName String
  description String
  colorHex    String
  iconKey     String

  asPrimary   CreatureSpecies[] @relation("PrimaryAffinity")
  asSecondary CreatureSpecies[] @relation("SecondaryAffinity")
  attackers   AffinityMatchup[] @relation("AttackerAffinity")
  defenders   AffinityMatchup[] @relation("DefenderAffinity")
  abilities   CreatureAbility[]
}

model AffinityMatchup {
  id                 String        @id @default(cuid())
  attackerAffinityId String
  defenderAffinityId String
  result             MatchupResult
  modifierBps        Int           @default(10000)

  attacker Affinity @relation("AttackerAffinity", fields: [attackerAffinityId], references: [id])
  defender Affinity @relation("DefenderAffinity", fields: [defenderAffinityId], references: [id])

  @@unique([attackerAffinityId, defenderAffinityId])
}

model CreatureSpecies {
  id                   String       @id @default(cuid())
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  internalId           String       @unique
  name                 String
  slug                 String       @unique
  shortDescription     String
  loreDescription      String
  primaryAffinityId    String
  secondaryAffinityId  String?
  baseRarity           Rarity
  baseStats            Json
  growthRates          Json
  maxLevel             Int          @default(50)
  hatchWeight          Int          @default(100)
  habitat              String
  temperament          String
  preferredFood        String
  idleAnimationKey     String
  battleAnimationKeys  Json
  soundKeys            Json
  spritePath           String
  artworkPath          String
  passiveAbilityKey    String
  generation           Int          @default(1)
  isActive             Boolean      @default(true)
  prismaticChanceBps   Int          @default(50)

  primaryAffinity   Affinity          @relation("PrimaryAffinity", fields: [primaryAffinityId], references: [id])
  secondaryAffinity Affinity?         @relation("SecondaryAffinity", fields: [secondaryAffinityId], references: [id])
  abilities         SpeciesAbility[]
  variants          CreatureVariant[]
  evolutionFrom     EvolutionRule[]   @relation("EvolutionFrom")
  evolutionTo       EvolutionRule[]   @relation("EvolutionTo")
  creatures         Creature[]
  hatchAttempts     HatchAttempt[]

  @@index([baseRarity])
  @@index([isActive])
  @@index([hatchWeight])
}

model CreatureVariant {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  speciesId   String
  key         String
  displayName String
  artworkPath String
  isPrismatic Boolean  @default(false)
  weight      Int      @default(100)

  species   CreatureSpecies @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  creatures Creature[]

  @@unique([speciesId, key])
}

model CreatureAbility {
  id            String          @id @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  key           String          @unique
  name          String
  description   String
  affinityId    String?
  category      AbilityCategory
  basePower     Int             @default(0)
  accuracy      Int             @default(100)
  energyCost    Int             @default(0)
  priority      Int             @default(0)
  cooldownTurns Int             @default(0)
  target        String          @default("OPPONENT")
  statusEffect  String?
  animationKey  String
  soundKey      String
  aiWeight      Int             @default(100)
  unlockLevel   Int             @default(1)

  affinity Affinity?         @relation(fields: [affinityId], references: [id])
  species  SpeciesAbility[]
  learned  CreatureLearnedAbility[]
}

model SpeciesAbility {
  id         String @id @default(cuid())
  speciesId  String
  abilityId  String
  slot       Int
  unlockLevel Int   @default(1)

  species CreatureSpecies  @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  ability CreatureAbility  @relation(fields: [abilityId], references: [id], onDelete: Cascade)

  @@unique([speciesId, slot])
  @@unique([speciesId, abilityId])
}

model EvolutionRule {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  fromSpeciesId   String
  toSpeciesId     String
  branchKey       String
  minLevel        Int      @default(1)
  requiredBond    Int?
  requiredItemKey String?
  requiredQuestId String?
  requiredAffinity AffinityName?
  timeOfDay       String?
  irreversible    Boolean  @default(true)
  description     String

  fromSpecies CreatureSpecies @relation("EvolutionFrom", fields: [fromSpeciesId], references: [id])
  toSpecies   CreatureSpecies @relation("EvolutionTo", fields: [toSpeciesId], references: [id])

  @@unique([fromSpeciesId, branchKey])
}

// ─── Eggs & Hatching ─────────────────────────────────────────────────────────

model OddsVersion {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  version     Int      @unique
  label       String
  odds        Json
  active      Boolean  @default(false)
  publishedAt DateTime?
  notes       String?

  eggs          Egg[]
  hatchAttempts HatchAttempt[]
}

model EggType {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  key                String   @unique
  eggClass           EggClass
  displayName        String
  description        String
  appearanceKey      String
  incubationHours    Int      @default(6)
  possibleAffinities Json
  possibleRarities   Json
  active             Boolean  @default(true)

  eggs Egg[]
}

model Egg {
  id                   String               @id @default(cuid())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  ownerId              String?
  eggTypeId            String
  eggClass             EggClass
  acquisitionMethod    EggAcquisitionMethod
  sourceKind           EggSourceKind        @default(STARTER)
  generation           Int                  @default(1)
  accountBound          Boolean              @default(false)
  sellable             Boolean              @default(true)
  parentACreatureId    String?
  parentBCreatureId    String?
  tradeCooldownUntil   DateTime?
  acquisitionAt        DateTime             @default(now())
  incubationStartedAt  DateTime?
  hatchReadyAt         DateTime?
  expiresAt            DateTime?
  status               EggStatus            @default(OWNED)
  appearanceKey        String
  oddsVersionId        String
  txReference          String?
  metadata             Json?
  careBoostCosmeticBps Int                  @default(0)
  version              Int                  @default(0)

  owner         User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  eggType       EggType       @relation(fields: [eggTypeId], references: [id])
  oddsVersion   OddsVersion   @relation(fields: [oddsVersionId], references: [id])
  hatchAttempts HatchAttempt[]
  creature      Creature?
  listings      MarketplaceListing[]

  @@index([ownerId, status])
  @@index([status, hatchReadyAt])
  @@index([sourceKind, status])
  @@unique([ownerId, acquisitionMethod, txReference])
}

model HatchAttempt {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  userId           String
  eggId            String
  requestId        String           @unique
  randomnessSource RandomnessSource @default(SERVER_CSPRNG)
  rollValue        Int
  oddsVersionId    String
  rarity           Rarity
  speciesId        String
  variantKey       String?
  isPrismatic      Boolean          @default(false)
  integrityHash    String
  serverSignature  String?
  resultPayload    Json

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  egg         Egg             @relation(fields: [eggId], references: [id], onDelete: Cascade)
  oddsVersion OddsVersion     @relation(fields: [oddsVersionId], references: [id])
  species     CreatureSpecies @relation(fields: [speciesId], references: [id])

  @@index([userId, createdAt])
  @@index([eggId])
}

// ─── Creatures ───────────────────────────────────────────────────────────────

model Creature {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  creatureNumber     Int
  customName         String?
  speciesId          String
  variantId          String?
  ownerId            String
  originalOwnerId    String
  eggId              String?           @unique
  rarity             Rarity
  isPrismatic        Boolean           @default(false)
  level              Int               @default(1)
  experience         Int               @default(0)
  lifecycle          CreatureLifecycle @default(STABLE)
  hunger             Int               @default(80)
  happiness          Int               @default(80)
  hygiene            Int               @default(80)
  energy             Int               @default(80)
  bond               Int               @default(20)
  health             Int               @default(100)
  maxHealth          Int               @default(100)
  mood               String            @default("curious")
  ageHours           Int               @default(0)
  careStreak         Int               @default(0)
  lastCareAt         DateTime?
  lastDecayAt        DateTime          @default(now())
  protectionUntil    DateTime?
  hatchedAt          DateTime          @default(now())
  battleWins         Int               @default(0)
  battleLosses       Int               @default(0)
  isFavorite         Boolean           @default(false)
  isOnActiveTeam     Boolean           @default(false)
  teamSlot           Int?
  cosmeticSkinKey    String?
  generation         Int               @default(1)
  founderStatus      Boolean           @default(false)
  breedingUsesRemaining Int            @default(5)
  lastBredAt         DateTime?
  seasonalOrigin     String?
  version            Int               @default(0)

  species         CreatureSpecies          @relation(fields: [speciesId], references: [id])
  variant         CreatureVariant?         @relation(fields: [variantId], references: [id])
  owner           User                     @relation("CreatureOwner", fields: [ownerId], references: [id])
  originalOwner   User                     @relation("CreatureOriginalOwner", fields: [originalOwnerId], references: [id])
  egg             Egg?                     @relation(fields: [eggId], references: [id])
  learnedAbilities CreatureLearnedAbility[]
  statSnapshots   CreatureStatSnapshot[]
  careEvents      CreatureCareEvent[]
  statusEvents    CreatureStatusEvent[]
  evolutions      CreatureEvolution[]
  equipment       CreatureEquipment[]
  listings        MarketplaceListing[]
  memorial        Memorial?
  battleParts     BattleParticipant[]

  @@unique([ownerId, creatureNumber])
  @@index([ownerId, lifecycle])
  @@index([speciesId])
  @@index([rarity])
  @@index([isOnActiveTeam])
  @@index([generation])
}

model CreatureLearnedAbility {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  creatureId String
  abilityId  String
  slot       Int

  creature Creature        @relation(fields: [creatureId], references: [id], onDelete: Cascade)
  ability  CreatureAbility @relation(fields: [abilityId], references: [id])

  @@unique([creatureId, slot])
  @@unique([creatureId, abilityId])
}

model CreatureStatSnapshot {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  creatureId String
  level      Int
  stats      Json
  reason     String

  creature Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@index([creatureId, createdAt])
}

model CreatureCareEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  creatureId String
  userId     String
  action     String
  deltas     Json
  itemKey    String?
  requestId  String   @unique

  creature Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([creatureId, createdAt])
}

model CreatureStatusEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  creatureId String
  fromStatus CreatureLifecycle?
  toStatus   CreatureLifecycle
  reason     String

  creature Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@index([creatureId, createdAt])
}

model CreatureEvolution {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  creatureId      String
  fromSpeciesId   String
  toSpeciesId     String
  branchKey       String
  requestId       String   @unique

  creature Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)

  @@index([creatureId])
}

// ─── Items & Crafting ────────────────────────────────────────────────────────

model Item {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  key             String       @unique
  name            String
  description     String
  category        ItemCategory
  stackable       Boolean      @default(true)
  maxStack        Int          @default(99)
  tradeable       Boolean      @default(true)
  boundOnAcquire  Boolean      @default(false)
  iconPath        String
  rarity          Rarity       @default(COMMON)
  metadata        Json?
  active          Boolean      @default(true)

  inventory      InventoryItem[]
  transactions   ItemTransaction[]
  recipeOutputs  Recipe[]            @relation("RecipeOutput")
  recipeInputs   RecipeIngredient[]
  equipment      CreatureEquipment[]
}

model InventoryItem {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  itemId     String
  quantity   Int       @default(1)
  bound      Boolean   @default(false)
  expiresAt  DateTime?
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@unique([userId, itemId, bound])
  @@index([userId])
}

model ItemTransaction {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  itemId     String
  delta      Int
  reason     String
  requestId  String   @unique
  metadata   Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@index([userId, createdAt])
}

model EquipmentSlot {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)

  equipment CreatureEquipment[]
}

model CreatureEquipment {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  creatureId String
  slotId     String
  itemId     String

  creature Creature      @relation(fields: [creatureId], references: [id], onDelete: Cascade)
  slot     EquipmentSlot @relation(fields: [slotId], references: [id])
  item     Item          @relation(fields: [itemId], references: [id])

  @@unique([creatureId, slotId])
}

model Recipe {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  key             String   @unique
  name            String
  description     String
  outputItemId    String
  outputQuantity  Int      @default(1)
  craftDurationSec Int     @default(60)
  minPlayerLevel  Int      @default(1)
  requiredRegionKey String?
  active          Boolean  @default(true)

  outputItem  Item               @relation("RecipeOutput", fields: [outputItemId], references: [id])
  ingredients RecipeIngredient[]
  jobs        CraftingJob[]
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  itemId   String
  quantity Int

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  item   Item   @relation(fields: [itemId], references: [id])

  @@unique([recipeId, itemId])
}

model CraftingJob {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  recipeId    String
  status      CraftingJobStatus @default(QUEUED)
  startedAt   DateTime?
  readyAt     DateTime?
  claimedAt   DateTime?
  requestId   String            @unique

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id])

  @@index([userId, status])
}

// ─── World & Exploration ─────────────────────────────────────────────────────

model Region {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  key             String   @unique
  name            String
  description     String
  sortOrder       Int      @default(0)
  isPlayable      Boolean  @default(false)
  unlockLevel     Int      @default(1)
  unlockTier      TokenTier @default(VISITOR)
  mapAssetKey     String
  musicKey        String?
  comingLater     Boolean  @default(false)

  mapDefinition MapDefinition?
  progress      PlayerRegionProgress[]
  encounters    Encounter[]
  quests        Quest[]
}

model MapDefinition {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  regionId     String   @unique
  tilemapPath  String
  collisionKey String
  spawnZones   Json
  npcSpawns    Json
  pickupSpawns Json
  portals      Json

  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)
}

model PlayerRegionProgress {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          String
  regionId        String
  unlocked        Boolean   @default(false)
  discoveryPct    Int       @default(0)
  lastVisitedAt   DateTime?
  checkpointJson  Json?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  region Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([userId, regionId])
}

model Encounter {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String
  regionId      String
  wildSpeciesId String?
  hostility     Int       @default(50)
  resonance     Int       @default(0)
  status        String    @default("ACTIVE")
  seed          String
  expiresAt     DateTime
  resolvedAt    DateTime?
  result        String?
  requestId     String    @unique

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  region  Region            @relation(fields: [regionId], references: [id])
  actions EncounterAction[]
  battle  Battle?

  @@index([userId, status])
}

model EncounterAction {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  encounterId String
  action      String
  payload     Json?
  requestId   String   @unique

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

// ─── Battles ─────────────────────────────────────────────────────────────────

model Battle {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  kind            String       @default("PVE")
  status          BattleStatus @default(PENDING)
  challengerId    String
  defenderId      String?
  encounterId     String?      @unique
  seed            String
  randomnessRecord Json
  turnNumber      Int          @default(0)
  winnerUserId    String?
  expiresAt       DateTime?
  completedAt     DateTime?
  version         Int          @default(0)

  challenger   User                @relation("BattleChallenger", fields: [challengerId], references: [id])
  defender     User?               @relation("BattleDefender", fields: [defenderId], references: [id])
  encounter    Encounter?          @relation(fields: [encounterId], references: [id])
  participants BattleParticipant[]
  turns        BattleTurn[]
  events       BattleEvent[]
  bossAttempt  BossAttempt?

  @@index([challengerId, status])
  @@index([status, expiresAt])
}

model BattleParticipant {
  id           String  @id @default(cuid())
  battleId     String
  creatureId   String?
  side         String
  snapshot     Json
  currentHp    Int
  currentEnergy Int
  fainted      Boolean @default(false)

  battle   Battle    @relation(fields: [battleId], references: [id], onDelete: Cascade)
  creature Creature? @relation(fields: [creatureId], references: [id], onDelete: SetNull)

  @@index([battleId])
}

model BattleTurn {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  battleId   String
  turnNumber Int
  actions    Json
  resultLog  Json

  battle  Battle         @relation(fields: [battleId], references: [id], onDelete: Cascade)
  actions_ BattleAction[]

  @@unique([battleId, turnNumber])
}

model BattleAction {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  battleId   String?
  turnId     String
  actorSide  String
  abilityKey String?
  payload    Json
  requestId  String   @unique

  turn BattleTurn @relation(fields: [turnId], references: [id], onDelete: Cascade)
}

model BattleEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  battleId   String
  sequence   Int
  eventType  String
  payload    Json

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, sequence])
}

// ─── Quests & Achievements ───────────────────────────────────────────────────

model Quest {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  key           String        @unique
  name          String
  description   String
  category      QuestCategory
  chainKey      String?
  requirements  Json
  startConditions Json
  expirationHours Int?
  repeatable    Boolean       @default(false)
  regionId      String?
  npcKey        String?
  active        Boolean       @default(true)
  sortOrder     Int           @default(0)

  region      Region?          @relation(fields: [regionId], references: [id])
  objectives  QuestObjective[]
  rewards     QuestReward[]
  playerQuests PlayerQuest[]
}

model QuestObjective {
  id          String @id @default(cuid())
  questId     String
  key         String
  description String
  targetCount Int    @default(1)
  metric      String

  quest    Quest                 @relation(fields: [questId], references: [id], onDelete: Cascade)
  progress PlayerQuestProgress[]

  @@unique([questId, key])
}

model QuestReward {
  id       String @id @default(cuid())
  questId  String
  kind     String
  payload  Json

  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)
}

model PlayerQuest {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  userId      String
  questId     String
  status      String    @default("ACTIVE")
  acceptedAt  DateTime  @default(now())
  completedAt DateTime?
  claimedAt   DateTime?
  expiresAt   DateTime?

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest    Quest                 @relation(fields: [questId], references: [id])
  progress PlayerQuestProgress[]

  @@index([userId, status])
  @@unique([userId, questId, acceptedAt])
}

model PlayerQuestProgress {
  id              String @id @default(cuid())
  playerQuestId   String
  objectiveId     String
  currentCount    Int    @default(0)

  playerQuest PlayerQuest    @relation(fields: [playerQuestId], references: [id], onDelete: Cascade)
  objective   QuestObjective @relation(fields: [objectiveId], references: [id])

  @@unique([playerQuestId, objectiveId])
}

model Achievement {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  key         String   @unique
  name        String
  description String
  iconKey     String
  points      Int      @default(10)
  criteria    Json
  active      Boolean  @default(true)

  players PlayerAchievement[]
}

model PlayerAchievement {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

// ─── Marketplace & Economy ───────────────────────────────────────────────────

model MarketplaceListing {
  id               String                     @id @default(cuid())
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  publicId         String                     @unique @default(cuid())
  sellerId         String
  creatureId       String?
  eggId            String?
  itemId           String?
  kind             MarketplaceListingKind     @default(PET)
  category         MarketplaceListingCategory @default(PETS)
  subfilter        String?
  bundleMode       ListingBundleMode?
  /// Integer lamports when currency is SOL; demo credits otherwise.
  priceLamports    String                     @default("0")
  priceCredits     Int
  feeCredits       Int
  listingFeeLamports String                   @default("0")
  currency         String                     @default("DEMO_CREDITS")
  status           MarketplaceListingStatus   @default(ACTIVE)
  expiresAt        DateTime
  viewCount        Int                        @default(0)
  version          Int                        @default(0)
  disclosureJson   Json?
  ownershipVerified Boolean                   @default(false)
  washRiskScore    Int                        @default(0)

  seller   User                       @relation(fields: [sellerId], references: [id])
  creature Creature?                  @relation(fields: [creatureId], references: [id])
  egg      Egg?                       @relation(fields: [eggId], references: [id])
  sale     MarketplaceSale?
  bundleItems MarketplaceListingBundleItem[]

  @@index([status, createdAt])
  @@index([sellerId])
  @@index([priceCredits])
  @@index([kind, status])
  @@index([category, status])
  @@index([eggId])
}

model MarketplaceListingBundleItem {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  listingId  String
  itemKey    String
  displayName String
  slot       String?
  /// Explicit opt-in only — never auto-include equipped gear.
  selectedBySeller Boolean @default(true)

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@unique([listingId, itemKey])
}

model MarketplaceSale {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  listingId       String   @unique
  buyerId         String
  sellerId        String
  priceCredits    Int
  feeCredits      Int
  priceLamports   String   @default("0")
  feeLamports     String   @default("0")
  requestId       String   @unique
  settlementMode  String   @default("DEMO_CREDITS")
  raritySnapshot  String?
  speciesSlug     String?

  listing MarketplaceListing @relation(fields: [listingId], references: [id])
  buyer   User               @relation("SaleBuyer", fields: [buyerId], references: [id])
  seller  User               @relation("SaleSeller", fields: [sellerId], references: [id])

  @@index([createdAt])
  @@index([raritySnapshot, createdAt])
  @@index([speciesSlug, createdAt])
}

model EggSupplyCounter {
  id               String        @id @default(cuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  sourceKind       EggSourceKind @unique
  sourceKey        String
  totalReleased    Int           @default(0)
  releasedToday    Int           @default(0)
  releasedThisWeek Int           @default(0)
  dayKey           String        @default("")
  weekKey          String        @default("")

  @@index([sourceKey])
}

model AssetTradeCooldown {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  assetKind  String
  assetId    String
  ownerId    String
  cooldownUntil DateTime

  @@unique([assetKind, assetId])
  @@index([ownerId, cooldownUntil])
}

model MarketplaceCancelCooldown {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  sellerId   String
  assetKind  String
  assetId    String
  cooldownUntil DateTime

  @@unique([sellerId, assetKind, assetId])
  @@index([cooldownUntil])
}

model CurrencyLedger {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  currency    String
  delta       Int
  balanceAfter Int
  reason      String
  requestId   String   @unique
  metadata    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RewardLedger {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  kind        String
  amount      Int      @default(0)
  payload     Json
  requestId   String   @unique
  legalOk     Boolean  @default(false)
  auditOk     Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model WithdrawalRequest {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  amountRaw   String
  status      String   @default("DISABLED")
  reason      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Community / Leaders / Memorials ─────────────────────────────────────────

model Season {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  key       String   @unique
  name      String
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(false)

  leaderboardEntries LeaderboardEntry[]
  communityEvents    CommunityEvent[]
}

model CommunityEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  key         String   @unique
  name        String
  description String
  seasonId    String?
  startsAt    DateTime
  endsAt      DateTime
  active      Boolean  @default(false)
  metadata    Json?

  season Season?       @relation(fields: [seasonId], references: [id])
  boss   CommunityBoss?
}

model CommunityBoss {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  eventId         String   @unique
  name            String
  maxHealth       Int
  currentHealth   Int
  dailyAttemptCap Int      @default(3)
  artworkPath     String
  active          Boolean  @default(true)

  event    CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attempts BossAttempt[]
}

model BossAttempt {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  bossId      String
  userId      String
  battleId    String?  @unique
  damageDealt Int      @default(0)
  requestId   String   @unique

  boss   CommunityBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  battle Battle?       @relation(fields: [battleId], references: [id])

  @@index([bossId, userId, createdAt])
}

model LeaderboardEntry {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  kind      LeaderboardKind
  scope     SeasonScope     @default(ALL_TIME)
  seasonId  String?
  userId    String
  score     Int
  rank      Int?
  disqualified Boolean      @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id])

  @@unique([kind, scope, seasonId, userId])
  @@index([kind, scope, score])
}

model Memorial {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  creatureId    String    @unique
  userId        String
  epitaph       String?
  tribute       String?
  publicVisible Boolean   @default(true)
  lifeHours     Int
  favoriteItem  String?
  moderated     Boolean   @default(false)

  creature Creature @relation(fields: [creatureId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  userId    String
  type      NotificationType
  title     String
  body      String
  payload   Json?
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

// ─── Admin / System ──────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  reason     String?
  metadata   Json?
  requestId  String?

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([entityType, entityId])
}

model AdminAction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  adminId   String
  action    String
  reason    String
  payload   Json?

  admin User @relation(fields: [adminId], references: [id])

