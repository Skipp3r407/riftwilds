enum AllocationBucket {
  GROWTH
  PET_REWARDS
  OPERATIONS
  EVENTS
  EMERGENCY
}

enum RevenueDepositStatus {
  PENDING
  VERIFIED
  ALLOCATED
  REJECTED
  REVERSED
}

enum RewardEpochStatus {
  SCHEDULED
  SNAPSHOTTING
  FINALIZED
  CLAIMABLE
  CLOSED
  PAUSED
}

enum ClaimStatus {
  PENDING
  CLAIMABLE
  CLAIMED
  EXPIRED
  CANCELLED
}

