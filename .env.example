# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Set true to rewrite public traffic to /maintenance (health/ready stay up)
MAINTENANCE_MODE=false
SUPPORT_EMAIL=support@riftwilds.game

# Database (Neon / Supabase Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
SOLANA_RPC_URL=
SOLANA_RPC_FALLBACK_URL=
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=

# Token / wallets (override project.ts placeholders in production)
TOKEN_MINT_ADDRESS=COMING_SOON
TREASURY_WALLET=COMING_SOON
ADMIN_WALLETS=

# Pump.fun community dashboard (public)
# Leave unset / COMING_SOON for honest empty states — never invent metrics
NEXT_PUBLIC_PUMPFUN_MINT=
NEXT_PUBLIC_PUMPFUN_URL=
NEXT_PUBLIC_TOKEN_MINT=

# Server-only: Community Reward Treasury deposit verification
PET_REWARD_VAULT_VERIFY_TOKEN=

# Optional: Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Optional: Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Image generation pipeline (server/scripts only — never expose to the browser)
# cursor-local (default): writes GenerateImage batch specs under artifacts/assets/batches/
# openai: calls Images API when IMAGE_API_KEY or OPENAI_API_KEY is set
# replicate: requires REPLICATE_API_TOKEN (falls back to cursor-local batch if missing)
# none: dry / skip
IMAGE_PROVIDER=cursor-local
IMAGE_API_KEY=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
IMAGE_MODEL=dall-e-3
