# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Set true to rewrite public traffic to /maintenance (health/ready stay up)
MAINTENANCE_MODE=false
SUPPORT_EMAIL=support@riftwilds.game

# Database (Neon / Supabase Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Credits soft currency — optional Prisma persistence (CurrencyLedger + softCurrency).
# When true (default with CREDITS_PRISMA_ENABLED flag), authenticated users sync to DB.
# Demo keepers without a User row stay in-process memory only. Credits ≠ SOL.
CREDITS_PRISMA_ENABLED=true

# Live World persistence — optional Prisma WorldSaveState (migration prepared, not applied).
# Default false until prisma migrate + generate after approval. Memory/hot path always on.
WORLD_PERSISTENCE_PRISMA_ENABLED=false

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
SOLANA_RPC_URL=
SOLANA_RPC_FALLBACK_URL=
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=

# Token / wallets (override project.ts placeholders in production)
TOKEN_MINT_ADDRESS=COMING_SOON
TREASURY_WALLET=COMING_SOON
ADMIN_WALLETS=

# Pump.fun / community token (public)
# Powers community dashboard + header RIFT price ticker under SOL
# Leave unset / COMING_SOON for honest empty states — never invent metrics
NEXT_PUBLIC_PUMPFUN_MINT=
NEXT_PUBLIC_PUMPFUN_URL=
NEXT_PUBLIC_TOKEN_MINT=

# Server-only: Community Reward Treasury deposit verification
PET_REWARD_VAULT_VERIFY_TOKEN=

# Optional: Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Nakama local stack (docker compose) ─────────────────────────────────────
# Docs: docs/nakama.md
# Start: docker compose up -d
# Requires Docker Desktop on Windows. Never commit real console passwords.
#
# Master client switch (also gated by featureFlagDefaults.NAKAMA_ENABLED).
NEXT_PUBLIC_NAKAMA_ENABLED=false
NEXT_PUBLIC_NAKAMA_HOST=127.0.0.1
NEXT_PUBLIC_NAKAMA_PORT=7350
NEXT_PUBLIC_NAKAMA_CONSOLE_PORT=7351
NEXT_PUBLIC_NAKAMA_USE_SSL=false
# Client "server key" (Nakama defaultkey) — not a treasury secret.
NEXT_PUBLIC_NAKAMA_SERVER_KEY=defaultkey
NEXT_PUBLIC_NAKAMA_TRACE=false
#
# Server-only (console / HTTP key for admin RPCs)
NAKAMA_HTTP_KEY=defaulthttpkey
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=localdev
#
# Compose overrides (optional)
NAKAMA_DB_NAME=nakama
NAKAMA_DB_USER=postgres
NAKAMA_DB_PASSWORD=localdb
NAKAMA_DB_HOST_PORT=5433
NAKAMA_HTTP_PORT=7350
NAKAMA_GRPC_PORT=7349
NAKAMA_CONSOLE_PORT=7351
REDIS_HOST_PORT=6379
# Local Redis URL for app experiments (Nakama core does not require Redis)
REDIS_URL=redis://127.0.0.1:6379

# Optional: Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Optional: Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Image generation pipeline (server/scripts only — never expose to the browser)
# cursor-local (default): writes GenerateImage batch specs under artifacts/assets/batches/
# openai: calls Images API when IMAGE_API_KEY or OPENAI_API_KEY is set
# replicate: requires REPLICATE_API_TOKEN (falls back to cursor-local batch if missing)
# none: dry / skip
IMAGE_PROVIDER=cursor-local
IMAGE_API_KEY=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
IMAGE_MODEL=dall-e-3

# Optional: premium commercial narrator TTS (scripts/commercials/generate-vo.mjs)
# Without these, VO uses free Microsoft Edge neural voices via edge-tts (Python).
# OPENAI_API_KEY=          # reuse above — enables OpenAI TTS (voice: onyx)
# OPENAI_TTS_VOICE=onyx
# OPENAI_TTS_MODEL=tts-1-hd
# COMMERCIAL_TTS=edge      # force: openai | elevenlabs | edge | sapi
# EDGE_TTS_VOICE=en-US-ChristopherNeural
# EDGE_TTS_RATE=-12%

# Optional: ElevenLabs — comics storybook VO + commercial narrator
# Docs: docs/audio/ELEVENLABS_NARRATION.md
# Generate: npm run assets:narrate   (dry-run: npm run assets:narrate -- --dry-run)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # warm storytelling (Rachel); override as needed
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: Grok/xAI TTS for Riftling species cries (npm run assets:riftling-cries)
# Default engine is procedural original SFX (no key required).
# XAI_API_KEY=
# RIFTLING_CRIES_ENGINE=procedural   # or: grok

# Optional: Grok/xAI image generation for game library (npm run assets:generate:library)
# Default engine is procedural SVG→WebP (no key required). Never commit real keys.
# GAME_LIBRARY_ENGINE=procedural   # or: grok
# XAI_IMAGE_MODEL=grok-imagine-image
# GAME_LIBRARY_CONCURRENCY=10
# GAME_LIBRARY_GROK_DELAY_MS=1200

