# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local
.env.production
.env.development

# local scratch / agent temp
/tmp-*.json
/artifacts/**/*.log
/artifacts/prod-server*.log
/.cursor/
/.cache/

# Third-party discovery packs (raw zips / unrestricted mirrors) — never ship in public/
/private-assets/discovered/*
!/private-assets/discovered/.gitkeep
/private-assets/rejected/*
!/private-assets/rejected/.gitkeep
/private-assets/restricted/*
!/private-assets/restricted/.gitkeep
# approved/ may track small cleared sources later; still prefer git-lfs / local for large zips

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/*.db
/prisma/*.db-journal

/tmp-*.txt

